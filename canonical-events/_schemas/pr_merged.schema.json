{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://telecheck.dev/canonical-events/schemas/pr_merged.schema.json",
  "title": "PR Merged Event",
  "description": "Emitted by per-repo PR-merge GitHub Action. Records that a PR was merged into the repo's main branch. Authoritative source for completion_pct + throughput metrics on cockpit dashboard.",
  "type": "object",
  "required": ["schema_version", "event_id", "event_type", "source", "wall_clock_ts", "client_idempotency_key", "project_id", "payload"],
  "properties": {
    "schema_version": { "const": "v1" },
    "event_id": { "type": "string", "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$" },
    "event_type": { "const": "pr_merged" },
    "source": { "type": "string", "pattern": "^[a-z][a-z0-9_-]*-pr-merge-hook$" },
    "wall_clock_ts": { "type": "string", "format": "date-time" },
    "client_idempotency_key": { "type": "string", "minLength": 8 },
    "project_id": { "type": "string" },
    "payload": {
      "type": "object",
      "required": ["repo", "pr_number", "title", "merged_by", "author_agent_id", "merge_commit_sha", "codex_rounds", "codex_final_verdict", "lines_added", "lines_removed"],
      "properties": {
        "repo": { "type": "string", "description": "owner/repo format e.g. arthurmenson/telecheck-forms-intake" },
        "pr_number": { "type": "integer", "minimum": 1 },
        "title": { "type": "string", "minLength": 1, "maxLength": 280 },
        "merged_by": { "type": "string", "description": "GitHub login of merger" },
        "author_agent_id": { "type": "string", "description": "Authoring agent's canonical agent ID" },
        "ai_authored": { "type": "boolean", "description": "If true, cockpit applies iris 2px left-border + sparkle glyph per AI three-cue rule" },
        "merge_commit_sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
        "merged_into": { "type": "string", "default": "main" },
        "codex_rounds": { "type": "integer", "minimum": 0, "description": "Number of Codex adversarial-review rounds before APPROVE" },
        "codex_final_verdict": { "enum": ["approve", "approve-conditional", "skipped-pre-codex-availability"] },
        "codex_round_findings_total": { "type": "integer", "minimum": 0 },
        "codex_round_findings_by_severity": {
          "type": "object",
          "properties": {
            "critical": { "type": "integer", "minimum": 0 },
            "high": { "type": "integer", "minimum": 0 },
            "medium": { "type": "integer", "minimum": 0 },
            "low": { "type": "integer", "minimum": 0 }
          }
        },
        "lines_added": { "type": "integer", "minimum": 0 },
        "lines_removed": { "type": "integer", "minimum": 0 },
        "files_changed": { "type": "integer", "minimum": 0 },
        "linked_cr_id": { "type": "string", "pattern": "^CR-[0-9]+$" },
        "linked_dep_id": { "type": "string", "pattern": "^DEP-[0-9]+$" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
